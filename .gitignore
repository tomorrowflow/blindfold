# Phase worktrees live inside the repo so they fall within the harness sandbox root.
.worktrees/

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.ruff_cache/
*.egg-info/
.env

# Node (sandcastle harness deps — package.json/lock live under .sandcastle/, tracked there)
node_modules/

# Playwright web-verify suite (tests/web/) run artifacts
tests/web/test-results/
tests/web/playwright-report/
tests/web/blob-report/
frontend/test-results/

# graphify output
graphify-out/

# PyInstaller freeze output (ADR-0039, issue #184) -- `pyinstaller
# packaging/blindfold-proxy.spec` writes here; the frozen binary is a
# release/CI artifact, never committed.
/build/
/dist/

# macOS
.DS_Store
